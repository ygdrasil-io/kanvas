  "classificationRules": [
    {
      "classification": "target-supported",
      "meaning": "Complete pure Kotlin target contract has implementation evidence.",
      "minimumEvidenceKinds": [
        "fixture-provenance",
        "deterministic-dump",
        "cpu-oracle",
        "route-diagnostics"
      ],
      "promotionPolicy": "A GPU artifact is additionally required whenever a GPU route is claimed."
    },
    {
      "classification": "current-supported",
      "meaning": "Current code supports a narrower compatibility behavior with documented limits.",
      "minimumEvidenceKinds": [
        "deterministic-dump",
        "route-diagnostics"
      ],
      "promotionPolicy": "Must not imply complete target support or GPU renderer support."
    },
    {
      "classification": "tracked-gap",
      "meaning": "The target wants this behavior but implementation evidence is missing.",
      "minimumEvidenceKinds": [
        "route-diagnostics",
        "refusal-diagnostics"
      ],
      "promotionPolicy": "Must name the owning spec and next evidence gate before any support promotion."
    },
    {
      "classification": "DependencyGated",
      "meaning": "A required pure Kotlin dependency or contract is not delivered yet.",
      "minimumEvidenceKinds": [
        "route-diagnostics",
        "refusal-diagnostics"
      ],
      "promotionPolicy": "Must remain blocked until the dependency delivers target evidence."
    },
    {
      "classification": "fixture-gated",
      "meaning": "Code or current evidence exists, but normative fixtures, goldens, or provenance are missing.",
      "minimumEvidenceKinds": [
        "deterministic-dump",
        "route-diagnostics"
      ],
      "promotionPolicy": "Must not promote until fixture provenance is attached."
    },
    {
      "classification": "GPU-gated",
      "meaning": "CPU or text route evidence exists, but the GPU artifact route is missing or unpromoted.",
      "minimumEvidenceKinds": [
        "cpu-oracle",
        "route-diagnostics"
      ],
      "promotionPolicy": "Any GPU-claimed row without a GPU artifact must stay GPU-gated."
    },
    {
      "classification": "expected-unsupported",
      "meaning": "The behavior is outside the complete Kanvas target and has stable refusal policy.",
      "minimumEvidenceKinds": [
        "refusal-diagnostics"
      ],
      "promotionPolicy": "Must link the architecture or spec decision that keeps the refusal intentional."
    },
    {
      "classification": "drift-only",
      "meaning": "External comparison can be recorded but is never a normative oracle.",
      "minimumEvidenceKinds": [
        "route-diagnostics"
      ],
      "promotionPolicy": "Must not become target support without Kanvas-owned fixture, dump, CPU oracle, and required GPU evidence."
    }
  ],
  "requiredEvidenceKinds": [
    {
      "kind": "fixture-provenance",
      "dashboardField": "fixtureProvenance",
      "requiredWhen": "Required before target-supported promotion and before fixture-gated rows can move."
    },
    {
      "kind": "deterministic-dump",
      "dashboardField": "deterministicDumps",
      "requiredWhen": "Required before target-supported promotion and for current-supported compatibility rows."
    },
    {
      "kind": "cpu-oracle",
      "dashboardField": "cpuOracle",
      "requiredWhen": "Required before target-supported promotion and for CPU-only evidence samples."
    },
    {
      "kind": "gpu-artifact",
      "dashboardField": "gpuArtifacts",
      "requiredWhen": "Required whenever a row claims GPU support."
    },
    {
      "kind": "route-diagnostics",
      "dashboardField": "routeDiagnostics",
      "requiredWhen": "Required for every row that routes, gates, or refuses text/font behavior."
    },
    {
      "kind": "refusal-diagnostics",
      "dashboardField": "refusalDiagnostics",
      "requiredWhen": "Required for expected-unsupported rows, tracked gaps, and legacy gates."
    }
  ],
